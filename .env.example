# Upload API Configuration
# Set a strong API key for upload endpoint security
NEXT_PUBLIC_UPLOAD_API_KEY=your-secure-api-key-here

# HMAC secret for file hashing
UPLOAD_SECRET=your-upload-secret-here

# Note: RENDER environment variable is automatically set by Render.com
# Files will be saved to /var/data/uploads on Render
# or public/uploads locally
